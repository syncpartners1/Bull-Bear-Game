# Copy this to .env for local development
# Railway injects NODE_ENV and PORT automatically — do not set them in the dashboard

# --- Production (Railway) ---
# Set these in the Railway dashboard → Variables:

# Your Telegram bot token from @BotFather (e.g. 123456:ABCdef...)
# Used to verify that players are real Telegram users (HMAC check on initData)
# NEVER commit the real value — add it only in Railway Variables
TELEGRAM_BOT_TOKEN=your-bot-token-here

# NODE_ENV is set to "production" by Railway automatically
# PORT is set to 8080 by Railway automatically
# Live URL: https://bull-and-bear.up.railway.app

# VITE_SERVER_URL: leave blank — client connects to same origin as server
VITE_SERVER_URL=

# --- Local development ---
# Without TELEGRAM_BOT_TOKEN set locally, auth verification is skipped
# so you can test in a browser without a real Telegram session.
# NODE_ENV=development
# PORT=3001
