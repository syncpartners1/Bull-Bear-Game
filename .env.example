# Copy this to .env for local development
# Railway injects NODE_ENV and PORT automatically — do not set them in the dashboard

# --- Production (Railway) ---
# NODE_ENV is set to "production" by Railway automatically
# PORT is set to 8080 by Railway automatically — server binds to process.env.PORT
# Live URL: https://bull-and-bear.up.railway.app

# VITE_SERVER_URL: leave blank in production — the React client is served from the
# same origin as the server, so Socket.io connects automatically.
# Only set this if you ever split client and server onto separate services.
VITE_SERVER_URL=

# --- Local development ---
# NODE_ENV=development
# PORT=3001
# VITE_SERVER_URL=     ← leave blank; Vite proxy forwards /socket.io → localhost:3001
